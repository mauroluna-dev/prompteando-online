# Production env for docker-compose.prod.yml.
# Copy to `.env.production`, fill in real values, then:
#   docker compose --env-file .env.production -f docker-compose.prod.yml pull
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d
# Never commit the filled-in .env.production.

# ── App image ──
# Prebuilt image pulled from the registry (published by
# .github/workflows/release.yml). Defaults to GHCR :latest if unset;
# pin a version tag for reproducible deploys.
APP_IMAGE=ghcr.io/mauroluna-dev/prompteando-online:latest

# ── Postgres ──
# Compose interpolates these into the app/migrate DATABASE_URL and into
# the postgres container itself. Use a strong password.
POSTGRES_USER=prompteando
POSTGRES_PASSWORD=change-me-to-a-strong-secret
POSTGRES_DB=prompteando

# DATABASE_URL and REDIS_URL are derived automatically by
# docker-compose.prod.yml from the service names + POSTGRES_* above.
# You don't need to set them here; if you do, compose overrides them to
# point at the in-network postgres/redis services.

# ── Auth.js ──
# AUTH_SECRET: >=32 chars  ->  openssl rand -base64 32
AUTH_SECRET=
# AUTH_URL: the public URL the app is served at (used for OAuth callbacks)
AUTH_URL=https://your-domain.example

# ── GitHub OAuth — login app ──
# Callback URL: <AUTH_URL>/auth/callback/github
GITHUB_AUTH_CLIENT_ID=
GITHUB_AUTH_CLIENT_SECRET=

# ── GitHub OAuth — integrations app (separate OAuth App) ──
# Callback URL: <AUTH_URL>/api/integrations/github/oauth-callback
GITHUB_INTEGRATIONS_CLIENT_ID=
GITHUB_INTEGRATIONS_CLIENT_SECRET=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Crypto ──
# ENCRYPTION_KEY: base64 of 32 bytes  ->  openssl rand -base64 32
# Envelope encryption for GitHub access tokens at rest.
ENCRYPTION_KEY=

# ── Optional ──
# SENTRY_DSN=
NODE_ENV=production
