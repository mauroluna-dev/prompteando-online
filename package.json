{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/interfaces/http/server.ts",
    "start": "NODE_ENV=production bun src/interfaces/http/server.ts",
    "build": "bun run build.ts",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "prepare": "husky",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "db:psql": "docker compose exec postgres psql -U promptstash -d promptstash"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/drizzle-adapter": "^1.11.2",
    "@elysiajs/cors": "^1.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "lucide-react": "^0.545.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.75.0",
    "react-router": "^7.14.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.59.1"
  }
}
