# promptstash environment variables.
# Copy to `.env` (gitignored) and fill in the placeholders as each
# phase requires the value.
#
# Variables are grouped by the roadmap phase that introduces them.

# ───────────────────── P1 (this phase) ─────────────────────
DATABASE_URL=postgres://promptstash:promptstash@localhost:5432/promptstash
REDIS_URL=redis://localhost:6379

# ───────────────────── P3 (Auth.js + GitHub) ─────────────────────
# AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ───────────────────── P4 (Auth.js + Google) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ───────────────────── P10 (GitHub token at-rest encryption) ────
# ENCRYPTION_KEY: 32-byte key, base64 encoded.
# Example: openssl rand -base64 32
ENCRYPTION_KEY=

# ───────────────────── P16 (optional, observability) ────────────
SENTRY_DSN=
