# prompteando environment variables.
# Copy to `.env` (gitignored) and fill in the placeholders as each
# phase requires the value.
#
# Variables are grouped by the roadmap phase that introduces them.

# ───────────────────── P1 (this phase) ─────────────────────
DATABASE_URL=postgres://prompteando:prompteando@localhost:5432/prompteando
REDIS_URL=redis://localhost:6379

# ───────────────────── P3 (Auth.js + GitHub login) ─────────────────────
# AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=
# For local-only dev: http://localhost:3010
# Behind a public tunnel (e.g. https://3010.mauroluna.dev): set the
# tunnel URL so Auth.js generates correct callbacks.
AUTH_URL=http://localhost:3010
# OAuth App #1 — login (Auth.js).
# Authorization callback URL in GitHub OAuth App settings:
#   <AUTH_URL>/auth/callback/github
GITHUB_AUTH_CLIENT_ID=
GITHUB_AUTH_CLIENT_SECRET=

# ───────────────────── P4 (Auth.js + Google) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ───────────────────── P10 (GitHub integration) ─────────────────
# ENCRYPTION_KEY: required from P10. 32-byte key, base64-encoded.
# Used to encrypt the GitHub OAuth access token at-rest in the
# user_github_connection table (AES-256-GCM via CryptoPort).
# Generate with: openssl rand -base64 32
# Rotation: rotating without re-encrypting existing rows breaks
# every connected user. Plan a migration before rotating.
ENCRYPTION_KEY=

# OAuth App #2 — integrations (Settings → Connect GitHub).
# GitHub OAuth Apps allow only ONE Authorization callback URL each,
# so we register a SECOND OAuth App for the integrations connect
# flow with this callback URL:
#   <AUTH_URL>/api/integrations/github/oauth-callback
GITHUB_INTEGRATIONS_CLIENT_ID=
GITHUB_INTEGRATIONS_CLIENT_SECRET=

# ───────────────────── P16 (optional, observability) ────────────
SENTRY_DSN=
